%%{init: {'theme': 'base', 'flowchart': {'curve': 'linear'}}}%%
graph TD
    classDef main fill:#fff3e0,stroke:#ff9800,stroke-width:2px,color:#000
    classDef enet fill:#fce4ec,stroke:#e91e63,stroke-width:2px,color:#000
    classDef ecs fill:#e0f7fa,stroke:#00bcd4,stroke-width:2px,color:#000
    classDef data fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px,color:#000
    classDef editor fill:#e8f5e9,stroke:#4caf50,stroke-width:2px,color:#000
    classDef ext fill:#eceff1,stroke:#607d8b,stroke-width:2px,color:#000

    subgraph Editor["ToolKit Editor Integration"]
        style Editor fill:#f1f8e9,stroke:#8bc34a,stroke-width:2px,stroke-dasharray: 5 5,color:#000
        TKE["ToolKit Editor Interface"]:::editor
        CDV["CustomDataView<br/>(Network Component UI)"]:::editor
    end

    TKE -->|Inspects & Modifies| CDV

    subgraph ECS["ToolKit Engine ECS"]
        style ECS fill:#e0f7fa,stroke:#00bcd4,stroke-width:2px,color:#000
        E["ToolKit::Entity"]:::ecs
        E --> NC["NetworkComponent<br/>RPC & Network Variables"]:::ecs
    end
    
    CDV -.->|Configures| NC

    subgraph Initialization["Network Role Initialization"]
        style Initialization fill:#f5f5f5,stroke:#9e9e9e,stroke-width:2px,stroke-dasharray: 5 5,color:#000
        Role{"NetworkRole"}:::ext
        
        Role -- "Client" --> InitClient["StartAsClient()"]:::main
        Role -- "DedicatedServer" --> InitServer["StartAsServer()"]:::main
        Role -- "Host" --> InitHost["StartAsServer() & StartAsClient()"]:::main
    end

    subgraph Core["ToolKitNetworking Core"]
        style Core fill:#fff3e0,stroke:#ff9800,stroke-width:2px,color:#000
        NM["NetworkManager<br/>Lifecycle & Tick Orchestrator"]:::main
        NM --> |"If Server/Host"| GS["GameServer<br/>Authoritative Host"]:::main
        NM --> |"If Client/Host"| GC["GameClient<br/>Client Peer"]:::main
        NM --> |Owns| NSS["NetworkSpawnService<br/>Prefab Instantiator"]:::main
    end

    InitClient --> NM
    InitServer --> NM
    InitHost --> NM

    NC <--> |State & RPC Requests| NM

    subgraph Transport["Low-Level Transport (ENet)"]
        style Transport fill:#fce4ec,stroke:#e91e63,stroke-width:2px,color:#000
        GS -->|Binds Port| ENetS["ENet Host<br/>Reliable UDP"]:::enet
        GC -->|Connects to Host| ENetC["ENet Peer<br/>Reliable UDP"]:::enet
    end

    subgraph Data["Data & Serialization Layer"]
        style Data fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px,color:#000
        PS["PacketStream<br/>Binary Stream Writer"]:::data
        NV["NetworkVariable<br/>Delta State Tracking"]:::data
        RPCR["RPC Registry<br/>Cross-DLL Hashing"]:::data
        
        NC -.-> |Serializes| NV
        NV -.-> |Encodes| PS
        NC -.-> |Looks up| RPCR
        RPCR -.-> |Encodes| PS
    end

    PS --> ENetS
    PS --> ENetC

    %% External
    ENetS <--> |UDP Packets| Internet((Internet)):::ext
    ENetC <--> |UDP Packets| Internet
